# Kommit web — environment variables template
# Copy to `.env.local` and fill in real values.
# `.env*.local` and `.env` are gitignored — never commit secrets.

# -----------------------------------------------------------------------------
# Site metadata
# -----------------------------------------------------------------------------

# Canonical public URL used by metadata, robots, and sitemap.
# Leave blank locally to use the built-in https://kommit.now fallback.
NEXT_PUBLIC_SITE_URL=

# Vercel injects these automatically in deployments. Leave blank locally unless
# testing Vercel-specific branches.
VERCEL_URL=
VERCEL_ENV=

# Next.js sets NODE_ENV. Leave blank in local env files.
NODE_ENV=

# -----------------------------------------------------------------------------
# Privy — embedded wallet auth
# -----------------------------------------------------------------------------

# Public Privy app ID bundled into the client.
NEXT_PUBLIC_PRIVY_APP_ID=

# Server-only Privy app secret for access-token verification.
PRIVY_APP_SECRET=

# -----------------------------------------------------------------------------
# Solana
# -----------------------------------------------------------------------------

# Public Solana RPC endpoint. Helius devnet/mainnet URLs are recommended.
NEXT_PUBLIC_HELIUS_RPC_URL=

# Optional public websocket RPC endpoint. If blank, the app derives ws/wss from
# NEXT_PUBLIC_HELIUS_RPC_URL.
NEXT_PUBLIC_HELIUS_WS_URL=

# Public deployed Kommit program ID.
NEXT_PUBLIC_KOMMIT_PROGRAM_ID=

# -----------------------------------------------------------------------------
# Supabase — Postgres indexer and service-role API writes
# -----------------------------------------------------------------------------

# Public Supabase project URL.
NEXT_PUBLIC_SUPABASE_URL=

# Public Supabase anon key. RLS/grants must enforce access control.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase service-role key. Bypasses RLS; never expose to clients.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Abuse controls and private fingerprints
# -----------------------------------------------------------------------------

# Server-only HMAC key for IP/email-derived fingerprints in waitlist, founder
# applications, and rate-limit identifiers.
WAITLIST_IP_HASH_KEY=

# -----------------------------------------------------------------------------
# Demo and sandbox gates
# -----------------------------------------------------------------------------

# Public local-dev demo flag. Set to "1" only for local demo mode.
NEXT_PUBLIC_KOMMIT_DEMO=

# Server-only feature gate for /api/sandbox/* routes. Set to "1" to enable.
SANDBOX_API_ENABLED=

# Server-only devnet fee-payer keypair for sandbox gas sponsorship and memo txs.
# Use base58 or a Solana CLI JSON array; keep devnet-only and rotate freely.
KOMMIT_DEVNET_FEE_PAYER_SECRET=
