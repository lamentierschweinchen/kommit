# Kommit web — environment variables template
# Copy to `.env.local` and fill in real values.
# `.env*.local` and `.env` are gitignored — never commit secrets.

# -----------------------------------------------------------------------------
# Privy — embedded wallet (passkey + email + Google), Solana support
# Sign up at privy.io → New App. Add allowed origins in Settings → Domains.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# -----------------------------------------------------------------------------
# Solana
# -----------------------------------------------------------------------------
# Helius RPC endpoint. Get from helius.dev → New Project.
# Devnet: https://devnet.helius-rpc.com/?api-key=<key>
NEXT_PUBLIC_HELIUS_RPC_URL=

# Helius API key (same key powers RPC + webhooks). Server-only.
HELIUS_API_KEY=

# Helius webhook bearer token. Set on the webhook in Helius dashboard.
HELIUS_WEBHOOK_SECRET=

# Deployed Kommit program ID. Devnet currently lives at:
# GxM3sxMp4FyrkHK4g1DaDrmwYLrwd2BJKxqKZqvGgkc3
NEXT_PUBLIC_KOMMIT_PROGRAM_ID=

# -----------------------------------------------------------------------------
# Supabase — Postgres indexer
# Sign up at supabase.com → New Project. Apply migrations from
# /Users/ls/Documents/Kommit/app/migrations/supabase/{0001,0002}_*.sql
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Waitlist (Lane A) — HMAC key for IP hashing
# Server-side only. Any sufficiently random secret (e.g. `openssl rand -hex 32`).
# /api/waitlist refuses to store rows without this set, so that a leaked DB
# dump can't be reversed against the small IPv4 dictionary without the key.
# -----------------------------------------------------------------------------
WAITLIST_IP_HASH_KEY=

# -----------------------------------------------------------------------------
# Pinata — IPFS metadata pinning
# Sign up at pinata.cloud → API Keys → New Key (admin scope).
# -----------------------------------------------------------------------------
PINATA_JWT=

# -----------------------------------------------------------------------------
# Demo mode — local dev convenience flag
# -----------------------------------------------------------------------------
# Set to "1" to activate demo mode locally: persona switcher, MockAuthProvider,
# localStorage-backed engagement loop (no API calls hit Supabase). Public
# visitors on the production deploy enter the same mode via the /demo entry
# page, which sets a localStorage flag instead of needing this env var.
# Server-side mock-wallet header acceptance ALSO requires
# `VERCEL_ENV !== "production"` so a leaked flag in prod env still fails closed.
NEXT_PUBLIC_KOMMIT_DEMO=

# -----------------------------------------------------------------------------
# Visa-rails sandbox demo (kommit.now/visa-demo) — see handoff 41
# -----------------------------------------------------------------------------
# When set to "live", the frontend's visa-demo-client routes hit the real
# /api/visa-demo/* endpoints under web/src/app/api/visa-demo/. Default
# (unset) keeps the in-memory stub at web/src/lib/visa-demo-stub.ts active.
# Public — bundled into the client.
NEXT_PUBLIC_VISA_SANDBOX=

# Server-only feature gate for the /api/visa-demo/* routes (Codex M1).
# Independent of NEXT_PUBLIC_VISA_SANDBOX above — without this flag set
# to "1", the routes return 503 + {error:"demo-api-disabled"} BEFORE the
# auth check. Both flags must be set together for the live integration to
# work (FE flag flips the client, server flag enables the routes). Default
# off so an accidental NEXT_PUBLIC_VISA_SANDBOX flip doesn't expose the
# server routes.
VISA_DEMO_API_ENABLED=

# MoonPay Commerce (Helio post-acquisition) sandbox API key. Sign up at
# https://hel.io → developer dashboard → sandbox project → API keys.
# Server-only. JWT-shaped (3-segment dotted format).
#
# Behavior without this key: the /api/visa-demo/onramp route fails closed
# with `moonpay-not-configured` (Codex M2 closure: no silent mock
# fallback). The /webhook handler also rejects all traffic until
# HELIO_WEBHOOK_SHARED_TOKEN is set.
HELIO_API_KEY=

# Parent Pay Link ID — the ID of the dynamic, card-payable Pay Link our
# charges hang off. Created once via:
#
#   HELIO_API_KEY=<key> \
#     HELIO_RECIPIENT_WALLET_ID=<id> HELIO_USDC_CURRENCY_ID=<id> \
#     HELIO_EUR_CURRENCY_ID=<id> \
#     node app/scripts/visa-demo-register-paylink.mjs
#
# Without this, the onramp route fails closed.
HELIO_PAYMENT_REQUEST_ID=

# Webhook signing secret returned at webhook-registration time. Used to
# verify HMAC-SHA256 signatures on incoming webhook deliveries. Created
# once via:
#
#   HELIO_API_KEY=<key> HELIO_PAYMENT_REQUEST_ID=<id> \
#     WEBHOOK_TARGET_URL=https://kommit.now/api/visa-demo/webhook \
#     node app/scripts/visa-demo-register-webhook.mjs
#
# Without this, the /api/visa-demo/webhook handler rejects ALL traffic
# (including legitimate MoonPay deliveries — completion events will be
# orphaned at the merchant wallet until restored). Re-run the registration
# script if lost.
HELIO_WEBHOOK_SHARED_TOKEN=

# Optional override for the MoonPay Commerce base URL. Defaults to
# https://api.dev.hel.io (sandbox). Override to https://api.hel.io for
# production once we're past devnet (post v0.5 work).
HELIO_BASE_URL=

# -----------------------------------------------------------------------------
# Devnet fee payer for visa-demo gas sponsorship + Memo logging
# -----------------------------------------------------------------------------
# The /api/visa-demo/pre-fund route sponsors devnet SOL into a caller's
# Privy embedded wallet so commit transactions can pay gas without the user
# seeing it. /onramp + /offramp also use this keypair to sign Memo txs that
# record sandbox events on-chain (Solscan-traceable for the submission
# video).
#
# One-time setup (do this on a trusted machine, then `rm` the tmp file):
#
#   solana-keygen new --no-bip39-passphrase --outfile /tmp/kommit-fp.json
#   FP_PUBKEY=$(solana-keygen pubkey /tmp/kommit-fp.json)
#   solana airdrop 5 "$FP_PUBKEY" --url devnet
#   solana airdrop 5 "$FP_PUBKEY" --url devnet     # devnet caps at 5/req; do twice for headroom
#   node -e "const fs=require('fs'),bs58=require('bs58');console.log(bs58.encode(Buffer.from(JSON.parse(fs.readFileSync('/tmp/kommit-fp.json')))))"
#   rm /tmp/kommit-fp.json
#
# Take the base58 output and set it here AND in Vercel preview/production
# env (Sensitive). Re-airdrop if balance drops below ~1 SOL during the
# demo. Devnet-only key — regenerate freely if compromised. Server-only.
KOMMIT_DEVNET_FEE_PAYER_SECRET=
