# Kommit — environment variables (template)
# Copy to `.env.local` (Next.js) or `.env` (server scripts) and fill in real values.
# NEVER commit actual `.env` files. `.env*` is ignored via .gitignore.
#
# Variables are grouped by service. All `NEXT_PUBLIC_*` vars are exposed to the
# browser; everything else is server-only and must never be referenced from
# client components.

# -----------------------------------------------------------------------------
# Solana
# -----------------------------------------------------------------------------

# RPC endpoint. Helius recommended for devnet+mainnet (webhooks, enhanced APIs).
# Devnet: https://devnet.helius-rpc.com/?api-key=...
# Mainnet: https://mainnet.helius-rpc.com/?api-key=...
NEXT_PUBLIC_HELIUS_RPC_URL=

# Helius API key. Same key powers the RPC URL above and the webhook indexer.
# Server-only — used by the indexer to register webhooks.
HELIUS_API_KEY=

# The deployed Kommit program ID. Replace placeholder after first `anchor build`
# + `anchor keys list`. Same value goes into Anchor.toml and programs/kommit/src/lib.rs.
NEXT_PUBLIC_KOMMIT_PROGRAM_ID=

# -----------------------------------------------------------------------------
# Privy — embedded wallet (passkey + social), Solana support
# -----------------------------------------------------------------------------

# Privy app ID. Public — embedded in the client bundle.
NEXT_PUBLIC_PRIVY_APP_ID=

# Privy app secret. Server-only — used for verifying tokens server-side.
PRIVY_APP_SECRET=

# -----------------------------------------------------------------------------
# IPFS — project metadata pinning
# -----------------------------------------------------------------------------

# Pinata JWT (preferred for v1 — easy onboarding, free tier).
# Alternative: Arweave / Bundlr for permanent storage (v2 consideration).
PINATA_JWT=

# -----------------------------------------------------------------------------
# Supabase — Postgres for posts, comments, curation flags, search, indexer
# -----------------------------------------------------------------------------

# Supabase project URL. Public.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key. Public — RLS policies must enforce all access control.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key. Server-only. Bypasses RLS — never expose to client.
SUPABASE_SERVICE_ROLE_KEY=
